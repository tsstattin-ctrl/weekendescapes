# Copy this file to .env.local and fill in your credentials
# Never commit .env.local to git

# SerpAPI - for Google Flights data
# Get your key at https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# Anthropic Claude API
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Booking.com Affiliate API
# Apply at https://www.booking.com/affiliate-program/v2/index.html
BOOKING_AFFILIATE_ID=your_affiliate_id_here
BOOKING_API_KEY=your_booking_api_key_here

# Cache duration in seconds (default: 2 hours)
CACHE_TTL=7200
